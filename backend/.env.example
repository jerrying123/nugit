# API
PORT=3001
DEBUG=false

# Database — leave empty for local-first mode (stack in `.nugit/` only).
# Set only if you use optional legacy Postgres tooling.
DATABASE_URL=

# Redis — optional; required for ARQ worker / webhook job enqueue
REDIS_URL=redis://localhost:6379

# GitHub App — create at github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=

# Optional
API_BASE_URL=http://localhost:3001
