{
  "name": "stackpr-vscode-plugin",
  "displayName": "Nugit",
  "description": "Stacked PR workflows: local .nugit/stack.json + GitHub REST",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:stackpr.login",
    "onCommand:stackpr.listMyPrs",
    "onCommand:stackpr.initStackFromPr",
    "onCommand:stackpr.showStack",
    "onCommand:stackpr.fetchRemoteStack",
    "onCommand:stackpr.savePat",
    "workspaceContains:**/.nugit/stack.json"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "commands": [
      { "command": "stackpr.login", "title": "Nugit: Login (device flow — needs GITHUB_OAUTH_CLIENT_ID)" },
      { "command": "stackpr.listMyPrs", "title": "Nugit: List My Open PRs" },
      { "command": "stackpr.initStackFromPr", "title": "Nugit: Init .nugit/stack.json" },
      { "command": "stackpr.showStack", "title": "Nugit: Load Local .nugit Stack" },
      { "command": "stackpr.fetchRemoteStack", "title": "Nugit: Fetch stack.json From GitHub" },
      { "command": "stackpr.savePat", "title": "Nugit: Save PAT to Secret Storage" }
    ],
    "viewsContainers": {
      "activitybar": [
        { "id": "stackpr", "title": "Nugit", "icon": "resources/icon.svg" }
      ]
    },
    "views": {
      "stackpr": [
        { "id": "stackpr.stackView", "name": "Stack" }
      ]
    }
  },
  "scripts": {
    "test": "vitest run"
  },
  "devDependencies": {
    "vitest": "^2.1.8"
  }
}
